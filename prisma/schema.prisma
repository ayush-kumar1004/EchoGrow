generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  businessName String
  contactName  String
  email        String
  businessType String?
  services     String?
  goals        String?
  status       String   @default("New")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model GeneratedCampaign {
  id                  String   @id @default(cuid())
  email               String?
  creativeType        String
  businessType        String
  campaignGoal        String
  creativeStyle       String
  targetAudience      String   // Stored as JSON string
  language            String
  inspirationBrands   String?
  businessDescription String
  extraDirection      String?
  generatedScript     String   // Stored as JSON string
  createdAt           DateTime @default(now())
}
